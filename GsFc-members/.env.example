## Copy this file to .env (for local dev) and fill in your own values.
## In Vercel, set the same variables under Project Settings -> Environment Variables.

# MongoDB Atlas connection string (Atlas dashboard -> Connect -> Drivers).
# Include the real database user password in place of <db_password>.
MONGODB_URI=mongodb+srv://<user>:<db_password>@cluster0.xxxxxxx.mongodb.net/?appName=Cluster0
MONGODB_DB_NAME=afc_gym

# Long random string used to sign session JWTs. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-string
