<body>

<div class="topbar">
  <div class="wrap" style="display:flex; align-items:center; justify-content:space-between; gap:10px; flex-wrap:wrap;">
    <div class="brand">
      <div class="logo">🏋️</div>
      <div>
        <div class="title">Grace Square Fitness Club</div>
        <div class="subtitle" id="memberCountLabel">— MEMBERS · LOADING</div>
      </div>
    </div>
    <button class="btn-gold" id="openAddBtn">+ Add Member</button>
  </div>
</div>

<div class="wrap" style="padding:16px 16px 0;">
  <div class="notice" id="dataNotice">↻ Syncing with Supabase…</div>

  <div class="cards" id="statCards"></div>

  <div style="margin-bottom:18px;">
    <div class="section-label">COLLECTION</div>
    <div class="period-row" id="periodRow"></div>
    <div class="date-row" id="customRangeRow" style="display:none;">
      📅 <input type="date" class="input" id="fromDate"> <span style="color:#6c8177; font-size:12.5px;">to</span> <input type="date" class="input" id="toDate">
    </div>
    <div class="collection-box">
      <div>
        <div class="collection-total" id="collectionTotal">₹0</div>
        <div class="collection-sub" id="collectionSub">0 registrations</div>
      </div>
      <div style="font-size:28px;">₹</div>
    </div>
  </div>

  <div style="margin-bottom:16px;">
    <div class="section-label">🏢 BUILDING DIRECTORY</div>
    <div class="tower-row" id="towerRow"></div>
  </div>

  <div class="search-row">
    <div class="search-wrap">
      <span class="search-icon">🔍</span>
      <input class="search-input" id="searchInput" placeholder="Search name, ID, wing, phone">
    </div>
    <button class="filter-btn" id="openFilterBtn">☰ Filters</button>
  </div>

  <div class="active-filters" id="activeFilters" style="display:none;"></div>
  <div class="count-line" id="countLine">0 SHOWN</div>

  <div class="table-wrap">
    <div class="table-scroll">
      <table>
        <thead>
          <tr>
            <th>Status</th><th>ID</th><th>Name</th><th>Wing/Flat</th><th>Contact</th>
            <th>Ends</th><th>Occupancy</th><th>Fees</th><th>Payment</th>
          </tr>
        </thead>
        <tbody id="memberRows"></tbody>
      </table>
    </div>
  </div>
</div>

<footer class="note">Runs entirely client-side · data reads and writes go straight to Supabase</footer>

<!-- Filter modal -->
<div class="modal-backdrop" id="filterModal">
  <div class="modal">
    <div class="modal-head"><div class="modal-title">Filters</div><button class="modal-close" id="closeFilterBtn">✕</button></div>
    <label class="field-label">Status</label>
    <select class="field-input" id="statusFilterSel">
      <option value="ALL">All</option>
      <option value="ACTIVE">Active only</option>
      <option value="INACTIVE">Inactive only</option>
    </select>
    <label class="field-label">Building / Tower</label>
    <select class="field-input" id="towerFilterSel"><option value="ALL">All towers</option></select>
    <button class="submit-btn" id="applyFilterBtn">Apply</button>
  </div>
</div>

<!-- Add member modal -->
<div class="modal-backdrop" id="addModal">
  <div class="modal">
    <div class="modal-head"><div class="modal-title">Add Member</div><button class="modal-close" id="closeAddBtn">✕</button></div>
    <form id="addForm">
      <label class="field-label">Full Name</label>
      <input class="field-input" id="f_name" required placeholder="e.g. Zoya Ansari">
      <label class="field-label">Gender</label>
      <select class="field-input" id="f_gender"><option value="M">Male</option><option value="F">Female</option></select>
      <label class="field-label">Wing / Flat</label>
      <input class="field-input" id="f_wing" placeholder="e.g. D4/1201">
      <label class="field-label">Contact Number</label>
      <input class="field-input" id="f_contact" placeholder="10-digit mobile">
      <label class="field-label">Occupancy</label>
      <select class="field-input" id="f_ownership"><option value="OWNER">Owner</option><option value="TENANT">Tenant</option><option value="RENT">Rent</option></select>
      <label class="field-label">Preferred Timing</label>
      <input class="field-input" id="f_timing" placeholder="e.g. MORNING">
      <label class="field-label">Fees</label>
      <input class="field-input" id="f_fees" value="700">
      <label class="field-label">Payment Type</label>
      <select class="field-input" id="f_payment"><option value="UPI">UPI</option><option value="CASH">Cash</option></select>
      <label class="field-label">Remark</label>
      <input class="field-input" id="f_remark" placeholder="e.g. Aadhaar pending">
      <button type="submit" class="submit-btn" id="submitLabel">Add Member</button>
    </form>
  </div>
</div>

