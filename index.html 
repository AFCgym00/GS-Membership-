  table { border-collapse: collapse; width: 100%; }
  th { text-align:left; font-family:'JetBrains Mono',monospace; font-size:10px; letter-spacing:0.06em; color:#6c8177; text-transform:uppercase; padding:9px 10px; border-bottom:1px solid #26362f; position:sticky; top:0; background:#0d1512; white-space:nowrap; }
  td { padding:9px 10px; border-bottom:1px solid #1b2622; font-size:13px; vertical-align:middle; white-space:nowrap; }
  tr:hover td { background:#131e1a; }
  ::-webkit-scrollbar { width:7px; height:7px; }
  ::-webkit-scrollbar-thumb { background:#2a3b33; border-radius:4px; }
  button, input, select { font-family:'Inter',sans-serif; }
  button:focus-visible, input:focus-visible, select:focus-visible { outline:2px solid #c9a24a; outline-offset:2px; }
  a { color:inherit; }
  .topbar { position:sticky; top:0; z-index:20; background:#0d1512ee; backdrop-filter:blur(6px); border-bottom:1px solid #1b2622; padding:14px 16px; }
  .wrap { max-width:1180px; margin:0 auto; }
  .brand { display:flex; align-items:center; gap:10px; min-width:0; }
  .logo { width:34px; height:34px; border-radius:8px; background:#c9a24a22; display:flex; align-items:center; justify-content:center; color:#c9a24a; flex-shrink:0; font-size:18px; }
  .title { font-family:'Space Grotesk',sans-serif; font-size:16px; font-weight:700; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
  .subtitle { font-size:10.5px; color:#6c8177; font-family:'JetBrains Mono',monospace; }
  .btn-gold { background:#c9a24a; color:#0d1512; border:none; border-radius:8px; padding:9px 14px; font-size:13px; font-weight:700; display:flex; align-items:center; gap:6px; cursor:pointer; flex-shrink:0; }
  .notice { display:flex; align-items:center; gap:8px; font-size:11.5px; color:#6c8177; background:#131e1a; border:1px solid #26362f; border-radius:8px; padding:8px 12px; margin-bottom:16px; }
  .cards { display:grid; grid-template-columns:repeat(4,1fr); gap:10px; margin-bottom:18px; overflow-x:auto; }
  @media (max-width:720px){ .cards{ grid-auto-flow:column; grid-auto-columns:130px; grid-template-columns:none; } }
  .card { background:#15201c; border:1px solid #26362f; border-radius:10px; padding:14px 16px; display:flex; flex-direction:column; gap:8px; min-width:0; }
  .card-head { display:flex; align-items:center; gap:8px; }
  .card-icon { width:26px; height:26px; border-radius:7px; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
  .card-label { font-family:'JetBrains Mono',monospace; font-size:10px; letter-spacing:0.06em; color:#7d9186; text-transform:uppercase; }
  .card-value { font-family:'Space Grotesk',sans-serif; font-size:22px; font-weight:600; color:#f2f5f1; line-height:1; }
  .card-sub { font-size:11px; color:#5e7268; }
  .section-label { font-family:'JetBrains Mono',monospace; font-size:10.5px; letter-spacing:0.06em; color:#6c8177; margin-bottom:8px; }
  .period-row { display:flex; gap:6px; margin-bottom:10px; flex-wrap:wrap; }
  .period-btn { background:#131e1a; color:#c7d1cb; border:1px solid #26362f; border-radius:7px; padding:7px 12px; font-size:12.5px; font-weight:600; cursor:pointer; }
  .period-btn.active { background:#7ba7c9; color:#0d1512; border-color:#7ba7c9; }
  .collection-box { background:linear-gradient(135deg,#15201c,#131e1a); border:1px solid #26362f; border-radius:10px; padding:16px 18px; display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:10px; }
  .collection-total { font-family:'Space Grotesk',sans-serif; font-size:26px; font-weight:700; color:#f2f5f1; }
  .collection-sub { font-size:11.5px; color:#6c8177; }
  .date-row { display:flex; gap:8px; margin-bottom:10px; align-items:center; flex-wrap:wrap; }
  .input, select.input { background:#0d1512; border:1px solid #26362f; border-radius:8px; padding:7px 10px; color:#e8ede9; font-size:13px; }
  .tower-row { display:flex; gap:7px; flex-wrap:wrap; }
  .tower-btn { background:#15201c; color:#c7d1cb; border:1px solid #26362f; border-radius:7px; padding:6px 11px; font-size:12px; font-weight:600; cursor:pointer; }
  .tower-btn.active { background:#c9a24a; color:#0d1512; border-color:#c9a24a; }
  .search-row { display:flex; gap:8px; margin-bottom:14px; }
  .search-wrap { position:relative; flex:1; }
  .search-icon { position:absolute; left:11px; top:10px; color:#5e7268; font-size:14px; }
  .search-input { width:100%; background:#0d1512; border:1px solid #26362f; border-radius:8px; padding:9px 12px 9px 32px; color:#e8ede9; font-size:14px; }
  .filter-btn { background:#131e1a; border:1px solid #26362f; border-radius:8px; padding:0 14px; color:#c7d1cb; display:flex; align-items:center; gap:6px; cursor:pointer; }
  .active-filters { display:flex; gap:8px; margin-bottom:12px; flex-wrap:wrap; font-size:12px; }
  .active-filters span { color:#c9a24a; }
  .active-filters button { background:none; border:none; color:#6c8177; text-decoration:underline; cursor:pointer; }
  .count-line { font-size:12px; color:#6c8177; margin-bottom:8px; font-family:'JetBrains Mono',monospace; }
  .table-wrap { border:1px solid #26362f; border-radius:10px; overflow:hidden; }
  .table-scroll { max-height:520px; overflow:auto; }
  .status-active { color:#5fae7c; font-weight:600; font-size:11.5px; display:flex; align-items:center; gap:5px; }
  .status-inactive { color:#a06a6a; font-weight:600; font-size:11.5px; display:flex; align-items:center; gap:5px; }
  .pill { font-size:11px; padding:3px 7px; border-radius:5px; font-weight:600; }
  .mono { font-family:'JetBrains Mono',monospace; color:#9fb0a6; }
  .name-cell { font-weight:600; color:#f2f5f1; }
  .modal-backdrop { position:fixed; inset:0; background:#05090780; backdrop-filter:blur(3px); display:none; align-items:flex-end; justify-content:center; z-index:50; }
  .modal-backdrop.open { display:flex; }
  .modal { background:#131e1a; border:1px solid #26362f; border-radius:16px 16px 0 0; width:100%; max-width:480px; max-height:88vh; overflow-y:auto; padding:20px; animation:slideUp 0.2s ease-out; }
  @keyframes slideUp { from{ transform:translateY(24px); opacity:0; } to{ transform:translateY(0); opacity:1; } }
  .modal-head { display:flex; justify-content:space-between; align-items:center; margin-bottom:16px; }
  .modal-title { font-family:'Space Grotesk',sans-serif; font-weight:600; font-size:17px; }
  .modal-close { background:none; border:none; color:#7d9186; cursor:pointer; font-size:20px; }
