const FIELDS = ["regDate","id","name","gender","wing","contact","startDate","endDate","ownership","timing","fees","paymentType","remark"];
// Supabase column -> app field name, matching FIELDS order above
const DB_COLUMNS = ["reg_date","member_id","name","gender","wing","contact","start_date","end_date","ownership","timing","fees","payment_type","remark"];
function rowFromDb(dbRow){
  return Object.fromEntries(FIELDS.map((f,i)=>[f, dbRow[DB_COLUMNS[i]] ?? ""]));
}

const MONTHS = {Jan:0,Feb:1,Mar:2,Apr:3,May:4,Jun:5,Jul:6,Aug:7,Sep:8,Oct:9,Nov:10,Dec:11};
function excelSerialToDate(n){ const utcDays = Math.floor(n - 25569); return new Date(utcDays*86400*1000); }
function parseFlexDate(str){
  if (!str) return null;
  const s = String(str).trim().replace(/-+$/,"");
  if (/^\d+$/.test(s)) return excelSerialToDate(parseInt(s,10));
  const m = /^(\d{1,2})-([A-Za-z]{3})-(\d{2,4})$/.exec(s);
  if (m){
    const day = parseInt(m[1],10);
    const mon = MONTHS[m[2].slice(0,1).toUpperCase()+m[2].slice(1,3).toLowerCase()];
    let yr = parseInt(m[3],10); if (yr<100) yr += 2000;
    if (mon===undefined) return null;
    return new Date(yr,mon,day);
  }
  return null;
}
function fmtDate(d){ if(!d) return "—"; return d.toLocaleDateString("en-GB",{day:"2-digit",month:"short",year:"2-digit"}); }
function isoDate(d){ return d.toISOString().slice(0,10); }
function towerOf(wing){ const m = /^([A-Za-z]+\d*)/.exec(wing||""); return m ? m[1] : "—"; }

const TODAY = new Date(); TODAY.setHours(0,0,0,0);

// ---- state ----
let roster = [];
let query = "";
let towerFilter = "ALL";
let statusFilter = "ALL";
let period = "today";
let customFrom = isoDate(new Date(2026,5,28));
let customTo = isoDate(TODAY);

async function loadRoster(){
  const notice = document.getElementById("dataNotice");
  const { data, error } = await sb
    .from("gsfc_members")
    .select("*")
    .order("reg_date", { ascending: true });

  if (error){
    notice.textContent = "⚠ Couldn't reach Supabase — check your schema.sql and API key. (" + error.message + ")";
    return;
  }

  roster = data.map(rowFromDb);
  notice.textContent = "↻ Live from Supabase · " + roster.length + " members loaded";
  render();
}

function getRoster(){ return roster; }
function enrich(roster){
  return roster.map(m => {
    const end = parseFlexDate(m.endDate);
    const reg = parseFlexDate(m.regDate);
    const active = end ? end >= TODAY : true;
    return {...m, _end:end, _reg:reg, _active:active};
  });
}

function nextId(roster){
  const nums = roster.map(m => parseInt((m.id||"").replace(/\D/g,""),10)).filter(n=>!isNaN(n));
  const max = nums.length ? Math.max(...nums) : 0;
  return "GSFC" + String(max+1).padStart(2,"0");
}

function render(){
  const roster = getRoster();
  const enriched = enrich(roster);

  document.getElementById("memberCountLabel").textContent = enriched.length + " MEMBERS · " + new Date().toLocaleDateString("en-GB",{day:"2-digit",month:"short",year:"numeric"});

  // stat cards
  const total = enriched.length;
  const active = enriched.filter(m=>m._active).length;
  const inactive = total - active;
  const pendingDocs = enriched.filter(m=>m.remark && m.remark.trim()).length;
  const cardsData = [
    {icon:"👥", label:"Total", value:total, accent:"#c9a24a"},
    {icon:"✅", label:"Active", value:active, accent:"#5fae7c"},
    {icon:"⛔", label:"Inactive", value:inactive, accent:"#8b5a5a"},
    {icon:"⚠️", label:"Docs Pending", value:pendingDocs, accent:"#d97757"}
  ];
  document.getElementById("statCards").innerHTML = cardsData.map(c => `
    <div class="card">
      <div class="card-head">
        <div class="card-icon" style="background:${c.accent}22; color:${c.accent};">${c.icon}</div>
        <span class="card-label">${c.label}</span>
      </div>
      <div class="card-value">${c.value}</div>
    </div>`).join("");

  // period buttons
  const periods = [["today","Today"],["week","This Week"],["month","This Month"],["custom","Custom"]];
  document.getElementById("periodRow").innerHTML = periods.map(([key,label]) =>
    `<button class="period-btn ${period===key?'active':''}" data-period="${key}">${label}</button>`
  ).join("");
  document.querySelectorAll(".period-btn").forEach(btn => btn.onclick = () => { period = btn.dataset.period; render(); });
  document.getElementById("customRangeRow").style.display = period === "custom" ? "flex" : "none";
  document.getElementById("fromDate").value = customFrom;
  document.getElementById("toDate").value = customTo;

  // collection calc
  let from, to;
  if (period === "today") { from = new Date(TODAY); to = new Date(TODAY); }
  else if (period === "week") {
    const dow = (TODAY.getDay()+6)%7;
    from = new Date(TODAY); from.setDate(TODAY.getDate()-dow);
    to = new Date(TODAY);
  } else if (period === "month") {
    from = new Date(TODAY.getFullYear(), TODAY.getMonth(), 1);
    to = new Date(TODAY);
  } else {
    from = new Date(customFrom); to = new Date(customTo);
  }
  const fromZero = new Date(from.getFullYear(),from.getMonth(),from.getDate());
  const toEnd = new Date(to.getFullYear(),to.getMonth(),to.getDate());
  const inRangeMembers = enriched.filter(m => m._reg && m._reg >= fromZero && m._reg <= toEnd);
  const collTotal = inRangeMembers.reduce((s,m)=>{ const n=parseInt(m.fees,10); return s+(isNaN(n)?0:n); },0);
  document.getElementById("collectionTotal").textContent = "₹" + collTotal.toLocaleString("en-IN");
  document.getElementById("collectionSub").textContent = `${inRangeMembers.length} registration${inRangeMembers.length!==1?'s':''} · ${fmtDate(fromZero)} – ${fmtDate(toEnd)}`;

  // towers
  const towerMap = {};
  enriched.forEach(m => { const t = towerOf(m.wing); towerMap[t] = (towerMap[t]||0)+1; });
  const towerCounts = Object.entries(towerMap).sort((a,b)=>b[1]-a[1]);
  document.getElementById("towerRow").innerHTML = towerCounts.map(([t,c]) =>
    `<button class="tower-btn ${towerFilter===t?'active':''}" data-tower="${t}">${t} <span style="opacity:.7">${c}</span></button>`
  ).join("");
  document.querySelectorAll(".tower-btn").forEach(btn => btn.onclick = () => {
    towerFilter = towerFilter === btn.dataset.tower ? "ALL" : btn.dataset.tower;
    render();
  });

  const towerSel = document.getElementById("towerFilterSel");
  towerSel.innerHTML = '<option value="ALL">All towers</option>' + towerCounts.map(([t])=>`<option value="${t}">${t}</option>`).join("");
  towerSel.value = towerFilter;
  document.getElementById("statusFilterSel").value = statusFilter;

  // active filter chips
  const chips = [];
  if (statusFilter!=="ALL") chips.push(`<span>Status: ${statusFilter}</span>`);
  if (towerFilter!=="ALL") chips.push(`<span>Tower: ${towerFilter}</span>`);
  const afEl = document.getElementById("activeFilters");
  if (chips.length){
    afEl.style.display = "flex";
    afEl.innerHTML = chips.join("") + '<button id="clearFiltersBtn">clear</button>';
    document.getElementById("clearFiltersBtn").onclick = () => { statusFilter="ALL"; towerFilter="ALL"; render(); };
  } else { afEl.style.display = "none"; afEl.innerHTML = ""; }

  // filtered rows
  const q = query.trim().toLowerCase();
  const filtered = enriched.filter(m => {
    if (towerFilter!=="ALL" && towerOf(m.wing)!==towerFilter) return false;
    if (statusFilter==="ACTIVE" && !m._active) return false;
    if (statusFilter==="INACTIVE" && m._active) return false;
    if (!q) return true;
    return m.name.toLowerCase().includes(q) || m.id.toLowerCase().includes(q) ||
      (m.wing||"").toLowerCase().includes(q) || (m.contact||"").includes(q);
  });
  document.getElementById("countLine").textContent = filtered.length + " SHOWN";

  document.getElementById("memberRows").innerHTML = filtered.map(m => {
    const ownerColor = m.ownership==="OWNER" ? "#7ba7c9" : m.ownership==="TENANT" ? "#c9a24a" : m.ownership==="RENT" ? "#d97757" : "#6c8177";
    const payColor = m.paymentType==="UPI" ? "#7ba7c9" : m.paymentType==="CASH" ? "#c9a24a" : "#d97757";
    return `<tr>
      <td><span class="${m._active?'status-active':'status-inactive'}">${m._active?'✅ Active':'⛔ Inactive'}</span></td>
      <td class="mono">${m.id}</td>
      <td class="name-cell">${m.name}</td>
      <td>${m.wing}</td>
      <td class="mono" style="font-size:12px;">${m.contact}</td>
      <td style="font-size:12px; color:#9fb0a6;">${m.endDate}</td>
      <td><span class="pill" style="background:${ownerColor}22; color:${ownerColor};">${m.ownership||"—"}</span></td>
      <td>₹${m.fees}</td>
      <td style="font-size:12px; color:${payColor};">${m.paymentType || (m.fees==="Payment Failed" ? "Failed" : "—")}</td>
    </tr>`;
  }).join("");
}

// ---- events ----
document.getElementById("searchInput").addEventListener("input", e => { query = e.target.value; render(); });
document.getElementById("fromDate").addEventListener("change", e => { customFrom = e.target.value; render(); });
document.getElementById("toDate").addEventListener("change", e => { customTo = e.target.value; render(); });

document.getElementById("openFilterBtn").onclick = () => document.getElementById("filterModal").classList.add("open");
document.getElementById("closeFilterBtn").onclick = () => document.getElementById("filterModal").classList.remove("open");
document.getElementById("filterModal").addEventListener("click", e => { if (e.target.id==="filterModal") e.target.classList.remove("open"); });
document.getElementById("applyFilterBtn").onclick = () => {
  statusFilter = document.getElementById("statusFilterSel").value;
  towerFilter = document.getElementById("towerFilterSel").value;
  document.getElementById("filterModal").classList.remove("open");
  render();
};

document.getElementById("openAddBtn").onclick = () => {
  document.getElementById("submitLabel").textContent = "Add Member (" + nextId(getRoster()) + ")";
  document.getElementById("addModal").classList.add("open");
};
document.getElementById("closeAddBtn").onclick = () => document.getElementById("addModal").classList.remove("open");
document.getElementById("addModal").addEventListener("click", e => { if (e.target.id==="addModal") e.target.classList.remove("open"); });

document.getElementById("addForm").addEventListener("submit", async e => {
  e.preventDefault();
  const name = document.getElementById("f_name").value.trim();
  if (!name) return;
  const id = nextId(getRoster());
  const regStr = TODAY.toLocaleDateString("en-GB",{day:"2-digit",month:"short",year:"2-digit"}).replace(/ /g,"-");
  const endD = new Date(TODAY.getFullYear(), TODAY.getMonth()+1, TODAY.getDate());
  const endStr = endD.toLocaleDateString("en-GB",{day:"2-digit",month:"short",year:"2-digit"}).replace(/ /g,"-");

  const submitBtn = document.getElementById("submitLabel");
  const prevLabel = submitBtn.textContent;
  submitBtn.textContent = "Saving…";
  submitBtn.disabled = true;

  const { error } = await sb.from("gsfc_members").insert({
    member_id: id,
    reg_date: regStr,
    name: name.toUpperCase(),
    gender: document.getElementById("f_gender").value,
    wing: document.getElementById("f_wing").value.trim(),
    contact: document.getElementById("f_contact").value.trim(),
    start_date: regStr,
    end_date: endStr,
    ownership: document.getElementById("f_ownership").value,
    timing: document.getElementById("f_timing").value.trim(),
    fees: document.getElementById("f_fees").value.trim(),
    payment_type: document.getElementById("f_payment").value,
    remark: document.getElementById("f_remark").value.trim()
  });

  submitBtn.disabled = false;
  submitBtn.textContent = prevLabel;

  if (error){
    alert("Couldn't save this member: " + error.message);
    return;
  }

  e.target.reset();
  document.getElementById("f_fees").value = "700";
  document.getElementById("addModal").classList.remove("open");
  await loadRoster();
});

loadRoster();
</script>
